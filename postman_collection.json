          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"cause_text\": \"반경 500m 내 카페 신규 개업 4건으로 경쟁 심화, 유동인구 20% 감소\",\n  \"profile_hint\": \"서울 서대문구 카페, 운영 1~3년\",\n  \"top_k\": 3\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{aiUrl}}/matching", "host": ["{{aiUrl}}"], "path": ["matching"] },
            "description": "기대: DEMO-0001(경쟁 심화 자금)이 상위 랭크. ANTHROPIC_API_KEY 필요(쿼리 변환이 Haiku)."
          }
        },
        {
          "name": "L3 원인 분석",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"profile\": {\n    \"industry\": \"카페/디저트\",\n    \"operating_period\": \"1~3년\",\n    \"monthly_revenue_band\": \"1,500만~3,000만\",\n    \"region_sido\": \"서울특별시\",\n    \"region_sigungu\": \"서대문구\",\n    \"concerns\": [\"주변 경쟁 심화\", \"자금 조달 어려움\"]\n  },\n  \"trigger_context\": {\n    \"metric_key\": \"new_competitors_500m\",\n    \"observed_value\": 4\n  }\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{aiUrl}}/analysis", "host": ["{{aiUrl}}"], "path": ["analysis"] },
            "description": "기대: {cause_text, needs_funding_match, match_hint}"
          }
        },
        {
          "name": "L5 리포트 생성",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"cause_text\": \"반경 500m 내 동일 업종 4곳이 새로 열려 경쟁이 심해졌고 유동인구도 20% 줄었습니다.\",\n  \"matches\": [\n    {\n      \"pblanc_id\": \"DEMO-0001\",\n      \"title\": \"소상공인 경쟁력 강화 특별자금 (경쟁 심화 업종)\",\n      \"rrf_score\": 0.032\n    }\n  ]\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{aiUrl}}/report/generate", "host": ["{{aiUrl}}"], "path": ["report", "generate"] },
            "description": "기대: {body_md} — 사장님 언어의 마크다운"
          }
        },
        {
          "name": "L2 1차 스크리닝 (선택)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"signal_summary\": \"서대문구 카페 상권: 신규 경쟁점 4곳, 유동인구 -20%\"\n}",
              "options": { "raw": { "language": "json" } }
