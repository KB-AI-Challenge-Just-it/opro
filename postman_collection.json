                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "url": { "raw": "{{aiUrl}}/index/rebuild", "host": ["{{aiUrl}}"], "path": ["index", "rebuild"] }
          }
        },
